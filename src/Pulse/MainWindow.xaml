<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Pulse.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="Nav" PaneDisplayMode="Left" OpenPaneLength="210"
                    IsSettingsVisible="False" IsBackButtonVisible="Collapsed"
                    SelectionChanged="Nav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Processes" Tag="processes" IsSelected="True">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8FD;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Performance" Tag="performance">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D2;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Startup apps" Tag="startup">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE7B5;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Settings" Tag="settings">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Grid Padding="20,12,20,16">
            <Grid.Resources>
                <Style x:Key="HeaderButton" TargetType="Button">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                </Style>
                <Style x:Key="StretchItem" TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
                <Style x:Key="StatKey" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                </Style>
                <Style x:Key="StatVal" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="20" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Style>
            </Grid.Resources>

            <!-- ===================== PROCESSES ===================== -->
            <Grid x:Name="ProcessesPanel" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="CPU" Style="{StaticResource StatKey}" />
                            <TextBlock x:Name="CpuValue" Text="0%" FontSize="28" FontWeight="SemiBold" />
                            <ProgressBar x:Name="CpuBar" Minimum="0" Maximum="100" Value="0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="MEMORY" Style="{StaticResource StatKey}" />
                            <TextBlock x:Name="MemValue" Text="0 / 0 GB" FontSize="28" FontWeight="SemiBold" />
                            <ProgressBar x:Name="MemBar" Minimum="0" Maximum="100" Value="0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CountText" Grid.Column="0" VerticalAlignment="Center"
                               Text="0 processes" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="EndBtn" Grid.Column="2" Content="End task" IsEnabled="False" Click="EndTask_Click" />
                </Grid>

                <Border Grid.Row="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1" Padding="10,0,10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Left"
                                Content="Name" Tag="name" Click="Header_Click" />
                        <Button Grid.Column="1" Style="{StaticResource HeaderButton}" Content="CPU" Tag="cpu" Click="Header_Click" />
                        <Button Grid.Column="2" Style="{StaticResource HeaderButton}" Content="Memory" Tag="mem" Click="Header_Click" />
                        <Button Grid.Column="3" Style="{StaticResource HeaderButton}" Content="Threads" Tag="threads" Click="Header_Click" />
                        <Button Grid.Column="4" Style="{StaticResource HeaderButton}" Content="PID" Tag="pid" Click="Header_Click" />
                        <TextBlock Grid.Column="5" Text="Status" HorizontalAlignment="Right" FontWeight="SemiBold"
                                   Padding="4,2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Border>

                <ListView x:Name="ProcList" Grid.Row="3" SelectionMode="Single"
                          ItemContainerStyle="{StaticResource StretchItem}"
                          SelectionChanged="ProcList_SelectionChanged"
                          DoubleTapped="ProcList_DoubleTapped">
                    <!-- No item transitions: rows update in place, no per-refresh animation/flicker. -->
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection />
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding CpuText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                <TextBlock Grid.Column="2" Text="{Binding MemText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                <TextBlock Grid.Column="3" Text="{Binding Threads}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                <TextBlock Grid.Column="4" Text="{Binding Pid}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                <TextBlock Grid.Column="5" Text="{Binding Status}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- ===================== PERFORMANCE ===================== -->
            <ScrollViewer x:Name="PerformancePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10">
                        <TextBlock x:Name="SysInfoText" Text="" FontSize="12.5" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CPU" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock x:Name="PerfCpuSub" Text="% Utilization over 60s" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="PerfCpuValue" Grid.Column="1" Text="0%" FontSize="34" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4">
                        <Grid x:Name="CpuGraphHost" Height="230" SizeChanged="CpuGraphHost_SizeChanged">
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                                <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                                <Border Grid.Row="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                            </Grid>
                            <Polygon x:Name="CpuFill" />
                            <Polyline x:Name="CpuLine" />
                        </Grid>
                    </Border>

                    <Grid ColumnSpacing="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="UTILIZATION" Style="{StaticResource StatKey}" /><TextBlock x:Name="StUtil" Text="0%" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="PROCESSES" Style="{StaticResource StatKey}" /><TextBlock x:Name="StProcs" Text="0" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="THREADS" Style="{StaticResource StatKey}" /><TextBlock x:Name="StThreads" Text="0" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="3"><TextBlock Text="LOGICAL CORES" Style="{StaticResource StatKey}" /><TextBlock x:Name="StCores" Text="0" Style="{StaticResource StatVal}" /></StackPanel>
                    </Grid>

                    <TextBlock Text="Logical processors" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <VariableSizedWrapGrid x:Name="CoreGrid" Orientation="Horizontal" ItemWidth="172" ItemHeight="98" MaximumRowsOrColumns="6" />

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Memory" FontWeight="SemiBold" />
                        <TextBlock x:Name="PerfMemValue" Grid.Column="1" Text="0 / 0 GB"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4">
                        <Grid x:Name="MemGraphHost" Height="120" SizeChanged="MemGraphHost_SizeChanged">
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                            </Grid>
                            <Polygon x:Name="MemFill" />
                            <Polyline x:Name="MemLine" />
                        </Grid>
                    </Border>

                    <!-- GPU -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="GpuTitle" Text="GPU" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock x:Name="GpuSub" Text="% Utilization over 60s" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="StGpuValue" Grid.Column="1" Text="0%" FontSize="34" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4">
                        <Grid x:Name="GpuGraphHost" Height="200" SizeChanged="GpuGraphHost_SizeChanged">
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                                <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                                <Border Grid.Row="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                            </Grid>
                            <Polygon x:Name="GpuFill" />
                            <Polyline x:Name="GpuLine" />
                        </Grid>
                    </Border>
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="UTILIZATION" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuUtil" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="MEMORY" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuMem" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="TEMPERATURE" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuTemp" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="3"><TextBlock Text="POWER" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuPower" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="4"><TextBlock Text="CORE CLOCK" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuClock" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="5"><TextBlock Text="FAN" Style="{StaticResource StatKey}" /><TextBlock x:Name="StGpuFan" Text="—" Style="{StaticResource StatVal}" /></StackPanel>
                    </Grid>

                    <!-- Disk -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Disk" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="% Active time over 60s" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="StDiskValue" Grid.Column="1" Text="0%" FontSize="34" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4">
                        <Grid x:Name="DiskGraphHost" Height="120" SizeChanged="DiskGraphHost_SizeChanged">
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                            </Grid>
                            <Polygon x:Name="DiskFill" />
                            <Polyline x:Name="DiskLine" />
                        </Grid>
                    </Border>
                    <Grid ColumnSpacing="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="ACTIVE TIME" Style="{StaticResource StatKey}" /><TextBlock x:Name="StDiskActive" Text="0%" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="READ" Style="{StaticResource StatKey}" /><TextBlock x:Name="StDiskRead" Text="0 MB/s" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="WRITE" Style="{StaticResource StatKey}" /><TextBlock x:Name="StDiskWrite" Text="0 MB/s" Style="{StaticResource StatVal}" /></StackPanel>
                    </Grid>

                    <!-- Network -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Network" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="Throughput over 60s" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="StNetValue" Grid.Column="1" Text="0 Mbps" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4">
                        <Grid x:Name="NetGraphHost" Height="120" SizeChanged="NetGraphHost_SizeChanged">
                            <Grid IsHitTestVisible="False">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Opacity="0.5" />
                            </Grid>
                            <Polygon x:Name="NetFill" />
                            <Polyline x:Name="NetLine" />
                        </Grid>
                    </Border>
                    <Grid ColumnSpacing="26" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="SEND" Style="{StaticResource StatKey}" /><TextBlock x:Name="StNetSend" Text="0 Mbps" Style="{StaticResource StatVal}" /></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="RECEIVE" Style="{StaticResource StatKey}" /><TextBlock x:Name="StNetRecv" Text="0 Mbps" Style="{StaticResource StatVal}" /></StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- ===================== STARTUP APPS ===================== -->
            <Grid x:Name="StartupPanel" Visibility="Collapsed" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Startup apps" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Apps that run when you sign in. Toggle user-scoped items to speed up boot; all-users items need admin."
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1" Padding="12,0,12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="Source" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="Enabled" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StartupList" Spacing="0" />
                </ScrollViewer>
            </Grid>

            <!-- ===================== SETTINGS ===================== -->
            <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
                    <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />

                    <!-- Default Task Manager -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Make Pulse the default Task Manager" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Opening Task Manager anywhere in Windows — Ctrl+Shift+Esc, the taskbar menu, Run → taskmgr — launches Pulse instead. This edits the registry (Image File Execution Options) and needs administrator approval. Turn it off to restore the built-in Task Manager." />
                                </StackPanel>
                                <ToggleSwitch x:Name="DefaultTmToggle" Grid.Column="1" VerticalAlignment="Center"
                                              OnContent="On" OffContent="Off" Toggled="DefaultTmToggle_Toggled" />
                            </Grid>
                            <TextBlock x:Name="DefaultTmStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Update speed -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Update speed" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="How often the live figures and graphs refresh." FontSize="12.5"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox x:Name="SpeedCombo" Grid.Column="1" VerticalAlignment="Center" MinWidth="150"
                                      SelectionChanged="SpeedCombo_SelectionChanged">
                                <ComboBoxItem Content="High — 0.5 s" Tag="500" />
                                <ComboBoxItem Content="Normal — 1 s" Tag="1000" IsSelected="True" />
                                <ComboBoxItem Content="Low — 2 s" Tag="2000" />
                                <ComboBoxItem Content="Battery saver — 4 s" Tag="4000" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- About -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="About" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock x:Name="AboutText" FontSize="12.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Pulse — a fast, native Windows Task Manager replacement." />
                            <HyperlinkButton Content="github.com/AverageCodeNerd/pulse" NavigateUri="https://github.com/AverageCodeNerd/pulse" Padding="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Window>
